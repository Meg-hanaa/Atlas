# Hindsight Cloud (from https://ui.hindsight.vectorize.io)
HINDSIGHT_API_KEY=your-hindsight-api-key
HINDSIGHT_BASE_URL=https://your-instance.hindsight.vectorize.io

# Groq (for cascadeflow model routing)
GROQ_API_KEY=your-groq-api-key

# Vision OCR — provide at least one
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Default subject slug (parameterized — change for other topics)
ATLAS_SUBJECT=ml-notes

# FastAPI backend URL (Streamlit frontend — use http://api:8000 in Docker)
ATLAS_API_URL=http://127.0.0.1:8000

# Auth (multi-user) — generate with: openssl rand -hex 32
ATLAS_AUTH_SECRET=change-me-use-openssl-rand-hex-32
ATLAS_JWT_LIFETIME_SECONDS=86400
# ATLAS_AUTH_DISABLED=1   # local dev / pytest only — never set in production

# Public URL for auth email links (Streamlit UI)
ATLAS_PUBLIC_URL=http://localhost:8501

# CORS — comma-separated origins allowed to call the API directly
ATLAS_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Email for verification / password reset (console prints tokens locally)
ATLAS_EMAIL_BACKEND=console
# ATLAS_EMAIL_BACKEND=smtp
# ATLAS_FROM_EMAIL=atlas@example.com
# ATLAS_SMTP_HOST=smtp.example.com
# ATLAS_SMTP_PORT=587
# ATLAS_SMTP_USER=
# ATLAS_SMTP_PASSWORD=

# Require verified email before login (optional)
# ATLAS_REQUIRE_EMAIL_VERIFICATION=1

# Auth rate limiting (per IP, per /auth/* path)
ATLAS_AUTH_RATE_MAX=10
ATLAS_AUTH_RATE_WINDOW=60

# HTTPS deploy — domain for Caddy (docker-compose)
# ATLAS_DOMAIN=atlas.example.com

# Optional: API root path when behind reverse proxy (Docker sets /api)
# ATLAS_API_ROOT_PATH=/api

# Optional: separate auth DB (defaults to data/auth.db)
# ATLAS_AUTH_DATABASE_URL=sqlite+aiosqlite:///./data/auth.db

# Google OAuth (optional — additive to email/password login)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   http://127.0.0.1:8000/auth/google/callback
# ATLAS_GOOGLE_OAUTH_CLIENT_ID=
# ATLAS_GOOGLE_OAUTH_CLIENT_SECRET=
# Public API URL used for OAuth redirect (defaults to http://127.0.0.1:8000)
# ATLAS_API_PUBLIC_URL=http://127.0.0.1:8000
# Override callback URL if needed (e.g. https://your.domain.com/api/auth/google/callback)
# ATLAS_GOOGLE_OAUTH_CALLBACK_URL=

# Render production (also in render.yaml)
# ATLAS_API_PUBLIC_URL=https://atlas-api-9v91.onrender.com
# ATLAS_PUBLIC_URL=https://atlas-app-shnc.onrender.com
# ATLAS_CORS_ORIGINS=https://atlas-app-shnc.onrender.com
